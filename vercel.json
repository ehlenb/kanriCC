{
  "framework": "vite",
  "devCommand": "npm run dev:ui",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/addin/:path*",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/ai?type=infer-status", "schedule": "0 2 * * *" }
  ]
}
